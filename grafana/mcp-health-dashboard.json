{
  "uid": "mcp-health",
  "title": "MCP Health",
  "tags": ["mcp-health"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Overview",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "collapsed": false
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total Tool Calls",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 1},
      "datasource": {"uid": "victoriametrics"},
      "targets": [
        {
          "expr": "sum(mcp_tool_calls_total)",
          "legendFormat": "total",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              {"color": "green", "value": null}
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Tool Calls / min",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 1},
      "datasource": {"uid": "victoriametrics"},
      "targets": [
        {
          "expr": "sum(rate(mcp_tool_calls_total[5m])) * 60",
          "legendFormat": "calls/min"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0",
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 50},
              {"color": "red", "value": 100}
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Error Rate %",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 1},
      "datasource": {"uid": "victoriametrics"},
      "targets": [
        {
          "expr": "sum(mcp_tool_calls_total{status=\"error\"}) / sum(mcp_tool_calls_total) * 100",
          "legendFormat": "error %",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "noValue": "0",
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 5},
              {"color": "red", "value": 10}
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "OFF DB Queries",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 1},
      "datasource": {"uid": "victoriametrics"},
      "targets": [
        {
          "expr": "sum(off_db_queries_total)",
          "legendFormat": "total",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0",
          "thresholds": {
            "steps": [
              {"color": "green", "value": null}
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "type": "row",
      "title": "MCP Tools",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5},
      "collapsed": false
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Tool Calls Over Time",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 6},
      "datasource": {"uid": "victoriametrics"},
      "targets": [
        {
          "expr": "sum by (tool) (increase(mcp_tool_calls_total[5m]))",
          "legendFormat": "{{tool}}"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "short"}
      }
    },
    {
      "id": 8,
      "type": "table",
      "title": "Tool Call Totals",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 6},
      "datasource": {"uid": "victoriametrics"},
      "targets": [
        {
          "expr": "sum by (tool, status) (mcp_tool_calls_total)",
          "legendFormat": "{{tool}} ({{status}})",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "sortBy",
          "options": {"sort": [{"field": "Value", "desc": true}]}
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Tool Latency p95",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 6},
      "datasource": {"uid": "victoriametrics"},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, tool) (rate(mcp_tool_latency_seconds_bucket[5m])))",
          "legendFormat": "{{tool}}"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "s"}
      }
    },
    {
      "id": 10,
      "type": "row",
      "title": "OpenFoodFacts",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 14},
      "collapsed": false
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "OFF DB Queries Over Time",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 15},
      "datasource": {"uid": "victoriametrics"},
      "targets": [
        {
          "expr": "sum by (method) (increase(off_db_queries_total[5m]))",
          "legendFormat": "{{method}}"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "short"}
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "OFF DB Latency p50/p95/p99",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 15},
      "datasource": {"uid": "victoriametrics"},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(off_db_latency_seconds_bucket[5m])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(off_db_latency_seconds_bucket[5m])))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(off_db_latency_seconds_bucket[5m])))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "s"}
      }
    },
    {
      "id": 13,
      "type": "table",
      "title": "OFF DB Query Totals",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 15},
      "datasource": {"uid": "victoriametrics"},
      "targets": [
        {
          "expr": "sum by (method) (off_db_queries_total)",
          "legendFormat": "{{method}}",
          "instant": true,
          "format": "table"
        }
      ]
    },
    {
      "id": 14,
      "type": "row",
      "title": "Business",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 23},
      "collapsed": false
    },
    {
      "id": 15,
      "type": "stat",
      "title": "Meals Logged (total)",
      "gridPos": {"h": 4, "w": 8, "x": 0, "y": 24},
      "datasource": {"uid": "victoriametrics"},
      "targets": [
        {
          "expr": "meals_logged_total",
          "legendFormat": "meals",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "short", "noValue": "0"}
      }
    },
    {
      "id": 16,
      "type": "stat",
      "title": "Products Created (total)",
      "gridPos": {"h": 4, "w": 8, "x": 8, "y": 24},
      "datasource": {"uid": "victoriametrics"},
      "targets": [
        {
          "expr": "products_created_total",
          "legendFormat": "products",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "short", "noValue": "0"}
      }
    },
    {
      "id": 17,
      "type": "stat",
      "title": "Weight Entries (total)",
      "gridPos": {"h": 4, "w": 8, "x": 16, "y": 24},
      "datasource": {"uid": "victoriametrics"},
      "targets": [
        {
          "expr": "weight_entries_total",
          "legendFormat": "entries",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "short", "noValue": "0"}
      }
    },
    {
      "id": 18,
      "type": "row",
      "title": "Database",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 28},
      "collapsed": false
    },
    {
      "id": 19,
      "type": "table",
      "title": "DB Operation Totals",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 29},
      "datasource": {"uid": "victoriametrics"},
      "targets": [
        {
          "expr": "sum by (operation) (db_operations_total)",
          "legendFormat": "{{operation}}",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "sortBy",
          "options": {"sort": [{"field": "Value", "desc": true}]}
        }
      ]
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "DB Latency p95",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 29},
      "datasource": {"uid": "victoriametrics"},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, operation) (rate(db_latency_seconds_bucket[5m])))",
          "legendFormat": "{{operation}}"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "s"}
      }
    }
  ]
}
